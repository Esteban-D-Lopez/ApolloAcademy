# Copy this file to .env and fill in your values
# Never commit .env to version control

# Required: used for document embeddings (ChromaDB) regardless of which chat provider is selected
GOOGLE_API_KEY=your_gemini_key_here

# Optional: only needed if you want the backend to have a default key for OpenAI or Anthropic.
# Users can also supply their own key directly in the Chat UI (stored in their browser only).
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
